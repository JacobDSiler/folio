// ───────────────────────────────────────────────────────────────────
// Folio — Cloud Storage security rules
// ───────────────────────────────────────────────────────────────────
// Verified against the app's actual Storage call sites (window._storage
// usage in app.html). Storage rules CAN read Firestore (firestore.get),
// so audio access is scoped to the owning folio's uid / published state.
// See docs/LAUNCH-READINESS.md → "Applying these rules".
// ───────────────────────────────────────────────────────────────────

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function folioDoc(folioId) {
      return firestore.get(
        /databases/(default)/documents/folio_projects/$(folioId)
      );
    }
    function isOwner(folioId) {
      let d = folioDoc(folioId);
      return request.auth != null
        && d != null
        && request.auth.uid == d.data.uid;
    }
    function isPublished(folioId) {
      let d = folioDoc(folioId);
      return d != null
        && d.data.release != null
        && d.data.release.published == true;
    }

    // Audiobook tracks — written by the app at
    //   folio_audio/<folioId>/<trackKey>
    match /folio_audio/{folioId}/{trackKey} {
      // Readable by the owner, or by anyone if the folio is published.
      // The published branch deliberately does NOT require auth, so
      // reader-mode streaming survives a pre-anonymous-auth race.
      allow read: if isPublished(folioId) || isOwner(folioId);
      // Only the owner uploads, replaces, or deletes tracks.
      allow write, delete: if isOwner(folioId);
    }

    // Lulu print-job PDFs — written at
    //   folio-lulu/<stamp>-interior.pdf  and  ...-cover.pdf
    // These are transient uploads with a flat, non-prefixed name, so
    // there's no per-user path segment to scope on — this can only be
    // gated to "any signed-in user". Audit polish item: re-path to
    // folio-lulu/<uid>/... so it can be owner-scoped.
    match /folio-lulu/{file} {
      allow read, write: if request.auth != null;
    }

    // Anything not matched above is denied by default.
  }
}
