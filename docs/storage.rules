// ───────────────────────────────────────────────────────────────────
// Folio — Cloud Storage security rules  ·  DRAFT for public-launch review
// ───────────────────────────────────────────────────────────────────
// Generated by the launch-readiness audit (see docs/LAUNCH-READINESS.md).
// Storage rules CAN read Firestore (firestore.get), so audio access is
// scoped to the owning folio's uid / published state.
//
// Before applying: confirm the bucket paths below match what the app
// actually writes (folio_audio/<folioId>/<trackKey> and folio-lulu/...).
// The folio-lulu/ path has no per-user prefix, so it can only be scoped
// to "any signed-in user" — see the audit for the re-pathing suggestion.
// ───────────────────────────────────────────────────────────────────

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function ownerUid(folioId) {
      return firestore.get(
        /databases/(default)/documents/folio_projects/$(folioId)
      ).data.uid;
    }
    function published(folioId) {
      let r = firestore.get(
        /databases/(default)/documents/folio_projects/$(folioId)
      ).data.release;
      return r != null && r.published == true;
    }

    // Audiobook tracks — readable by the owner or anyone who can see a
    // published folio; writable only by the owner.
    match /folio_audio/{folioId}/{trackKey} {
      allow read:  if request.auth != null
                   && (request.auth.uid == ownerUid(folioId)
                       || published(folioId));
      allow write, delete: if request.auth != null
                   && request.auth.uid == ownerUid(folioId);
    }

    // Lulu print-job PDFs (interior / cover). Transient uploads with a
    // flat <projId>-<timestamp> name — no per-user prefix to scope on,
    // so this falls back to "any signed-in user." Consider re-pathing
    // to folio-lulu/{uid}/... so it can be owner-scoped.
    match /folio-lulu/{file} {
      allow read, write: if request.auth != null;
    }
  }
}
