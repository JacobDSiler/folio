// ───────────────────────────────────────────────────────────────────
// Folio — Firestore security rules  ·  DRAFT for public-launch review
// ───────────────────────────────────────────────────────────────────
// Generated by the launch-readiness audit (see docs/LAUNCH-READINESS.md).
// This is a STARTING POINT, not a verified production ruleset. Before
// applying in the Firebase console:
//   1. Read docs/LAUNCH-READINESS.md → "Firestore rules" section.
//   2. Test from a logged-OUT browser: a published reader link must
//      load; a guessed UNPUBLISHED folio id must be denied.
//   3. The `subscribers` lockdown below WILL break the current in-app
//      unsubscribe page (it queries by token as an anonymous user).
//      Ship the locked-down subscribers rule together with the email
//      worker's server-side /unsubscribe endpoint (roadmap day 1).
//      Until then, the interim is `allow read: if true` on subscribers
//      — a known email-harvest risk, documented in the audit.
// ───────────────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }
    function parent(id) {
      return get(/databases/$(database)/documents/folio_projects/$(id)).data;
    }
    function isPublished(id) {
      let p = parent(id);
      return p.release != null && p.release.published == true;
    }

    match /folio_projects/{id} {
      // A non-owner may read ONLY a published folio. Unpublished
      // manuscripts are owner-only.
      allow read:   if isOwner(resource.data.uid)
                    || (resource.data.release != null
                        && resource.data.release.published == true);
      allow create: if isOwner(request.resource.data.uid);
      allow update, delete: if isOwner(resource.data.uid);

      // Manuscript body — same visibility as the parent.
      match /body/{doc} {
        allow read:  if isOwner(parent(id).uid) || isPublished(id);
        allow write: if isOwner(parent(id).uid);
      }

      // Version history — owner only.
      match /versions/{vid} {
        allow read, write: if isOwner(parent(id).uid);
      }

      // Live presence — readable by anyone who can see the folio,
      // writable only to your own presence doc.
      match /presence/{uid} {
        allow read:  if isOwner(parent(id).uid) || isPublished(id);
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Annotations. NOTE: rules can gate the COLLECTION but not
      // per-scope visibility (personal / editor / public). With these
      // rules, anyone who can read a published folio can read ALL its
      // annotations. See the audit's "private-annotation leak" item —
      // the real fix is structural (split scopes into subcollections).
      match /annotations/{aid} {
        allow read:   if isOwner(parent(id).uid) || isPublished(id);
        allow create: if request.auth != null
                      && request.resource.data.uid == request.auth.uid;
        allow update, delete: if isOwner(parent(id).uid)
                      || (request.auth != null
                          && resource.data.uid == request.auth.uid);
      }

      // Subscribers. The public subscribe form needs open CREATE.
      // READ/LIST is owner-only to prevent email harvesting — but see
      // the header note: this breaks the current unsubscribe page
      // until /unsubscribe moves into the email worker.
      match /subscribers/{sid} {
        allow create: if request.resource.data.keys()
                          .hasOnly(['email','subscribedAt','unsubscribeToken'])
                      && request.resource.data.email is string;
        allow read, update, delete: if isOwner(parent(id).uid);
      }
    }

    // Per-user app settings.
    match /folio_user_settings/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Lulu print-on-demand job records.
    match /lulu_jobs/{jobId} {
      allow read, write: if request.auth != null
                         && request.resource.data.uid == request.auth.uid;
    }
  }
}
