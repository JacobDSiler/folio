// ───────────────────────────────────────────────────────────────────
// Folio — Firestore security rules
// ───────────────────────────────────────────────────────────────────
// Verified against the app's actual Firestore access patterns (every
// _fb.* call site in app.html) during the launch-readiness audit.
// See docs/LAUNCH-READINESS.md → "Applying these rules" for how to
// publish + test these in the Firebase console.
//
// All collections are owner-gated except where public read is needed
// (published folios, their body, presence, and annotations). The
// subscribers subcollection is locked down too — its unsubscribe link
// now flows through the folio-email worker's /unsubscribe endpoint,
// which uses a service account (IAM) rather than browser auth.
// ───────────────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // request.auth.uid == uid, with the null-auth guard built in.
    function isUser(uid) {
      return request.auth != null && uid != null && request.auth.uid == uid;
    }
    // The parent folio_projects doc for a subcollection rule.
    function parentDoc(id) {
      return get(/databases/$(database)/documents/folio_projects/$(id));
    }
    function parentUid(id) {
      let d = parentDoc(id);
      return d != null ? d.data.uid : null;
    }
    function parentPublished(id) {
      let d = parentDoc(id);
      return d != null
        && d.data.release != null
        && d.data.release.published == true;
    }
    // Anyone who is allowed to SEE this folio: its owner, or anyone if
    // it's published.
    function folioVisible(id) {
      return isUser(parentUid(id)) || parentPublished(id);
    }

    match /folio_projects/{id} {
      // Read: the owner, or anyone if the folio is published.
      // A LIST query is only permitted when it's constrained to
      // where('uid','==', <me>) — the app's "my folios" query — because
      // then every result provably satisfies isUser(). An unfiltered
      // list of all folios is denied.
      allow read:   if isUser(resource.data.uid)
                    || (resource.data.release != null
                        && resource.data.release.published == true);

      // Create: the new doc must be stamped with the creator's own uid.
      allow create: if isUser(request.resource.data.uid);

      // Update / delete: must already own it. Checked against the
      // EXISTING doc — partial merge-updates (publishing a release,
      // setting shelfId) legitimately omit `uid` from the payload, so
      // the incoming data can't be relied on here.
      allow update, delete: if isUser(resource.data.uid);

      // Manuscript body subdoc — same visibility as the parent folio,
      // owner-only writes.
      match /body/{doc} {
        allow read:  if folioVisible(id);
        allow write: if isUser(parentUid(id));
      }

      // Version history — owner only, both directions.
      match /versions/{vid} {
        allow read, write: if isUser(parentUid(id));
      }

      // Live presence — readable by anyone who can see the folio; each
      // user may write only their own presence doc (it's keyed by uid).
      match /presence/{uid} {
        allow read:  if folioVisible(id);
        allow write: if isUser(uid);
      }

      // Annotations.
      // Per-doc scope enforcement (audit B4 — fixed). The folio owner
      // sees every annotation on their own folio; anyone else can read
      // an annotation only if its scope is 'public' OR they personally
      // authored it (uid match). Editor / collaborator / others'
      // personal notes no longer leak.
      //
      // A LIST query is permitted only when it's constrained so every
      // result satisfies one of those branches:
      //   • Owner — no filter needed (parentUid(id) is collection-level).
      //   • Non-owner — must query with either
      //       where('scope','==','public')
      //       where('uid','==', auth.uid)
      // The Folio client splits its subscription accordingly in
      // _annSubscribe / _annInitFromCloud.
      match /annotations/{aid} {
        allow read:   if isUser(parentUid(id))
                      || resource.data.scope == 'public'
                      || (request.auth != null
                          && resource.data.uid == request.auth.uid);
        // Create: stamped with your own uid — or anything, if you own
        // the folio (covers the owner migrating legacy annotations).
        allow create: if isUser(request.resource.data.uid)
                      || isUser(parentUid(id));
        // Update / delete: the annotation's author, or the folio owner.
        allow update, delete: if isUser(parentUid(id))
                      || isUser(resource.data.uid);
      }

      // Subscribers — the serial-release email list.
      match /subscribers/{sid} {
        // Anyone may CREATE a subscriber doc — that's the public
        // subscribe form. Restricted to exactly the three fields the
        // app writes (_subAdd), with a sane email length cap.
        allow create: if request.resource.data.keys()
                          .hasOnly(['email','subscribedAt','unsubscribeToken'])
                      && request.resource.data.email is string
                      && request.resource.data.email.size() < 320;

        // Locked down (audit B5 — done). Anonymous readers no longer
        // touch this subcollection: the unsubscribe link in chapter
        // emails now points at the folio-email worker's /unsubscribe
        // endpoint, which uses a Google service account (IAM, not
        // Firestore rules) to find + delete the matching doc. So
        // read + delete here are strictly the owner's prerogative —
        // closes the email-harvest / arbitrary-delete risk.
        allow read, delete: if isUser(parentUid(id));

        // Updates are owner-only regardless.
        allow update: if isUser(parentUid(id));
      }
    }

    // Per-user app settings — strictly your own.
    match /folio_user_settings/{uid} {
      allow read, write: if isUser(uid);
    }

    // Lulu print-on-demand job records. Doc id is "<uid>_<jobId>" and
    // the payload carries `uid`. create checks the incoming payload;
    // read / update / delete check the EXISTING doc (no payload on a
    // read or delete). The app's list query is constrained to
    // where('uid','==', <me>), so it satisfies the read rule.
    match /lulu_jobs/{jobId} {
      allow create: if isUser(request.resource.data.uid);
      allow read, update, delete: if isUser(resource.data.uid);
    }

    // Anything not matched above is denied by default.
  }
}
