// Combined rules for Boxes app + Folio Projects app
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /* ---------------------------------------------------------
     * BOXES APP
     * --------------------------------------------------------- */
    match /boxes/{boxId} {
      allow read, write: if true;
      match /items/{itemId} {
        allow read, write: if true;
      }
      match /vault/{vaultId} {
        allow read, write: if true;
      }
      match /signaling/{sigId} {
        allow read, write: if true;
        match /{subCol}/{subDoc} {
          allow read, write: if true;
        }
      }
    }
    match /_ping/{doc} {
      allow read, write: if true;
    }

// ───────────────────────────────────────────────────────────────────
// Folio — Firestore security rules
// ───────────────────────────────────────────────────────────────────
// Verified against the app's actual Firestore access patterns (every
// _fb.* call site in app.html) during the launch-readiness audit.
// See docs/LAUNCH-READINESS.md → "Applying these rules" for how to
// publish + test these in the Firebase console.
//
// All collections are owner-gated except where public read is needed
// (published folios, their body, presence, and annotations). The
// subscribers subcollection is locked down too — its unsubscribe link
// now flows through the folio-email worker's /unsubscribe endpoint,
// which uses a service account (IAM) rather than browser auth.
// ───────────────────────────────────────────────────────────────────

    // request.auth.uid == uid, with the null-auth guard built in.
    function isUser(uid) {
      return request.auth != null && uid != null && request.auth.uid == uid;
    }
    // Admin check — Folio platform operators. Two-layer allowlist:
    //   (1) Bootstrap uids hardcoded in source (safety net if role docs
    //       are ever deleted, and lets a fresh install still have an
    //       admin without pre-seeding data).
    //   (2) Dynamic uids in /folio_roles/{uid}.roles array = ['admin']
    //       — grantable via /admin/admins/ page.
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid in [
          'x9AgFZ7O8WVz2UVtyO4ggWKNfc73'  // Jacob — bootstrap admin
        ]
        || (
          exists(/databases/$(database)/documents/folio_roles/$(request.auth.uid))
          && 'admin' in get(/databases/$(database)/documents/folio_roles/$(request.auth.uid)).data.roles
        )
      );
    }
    // Moderator check — narrower role for shelf content approval only.
    // Admin is a superset (admins are always moderators).
    function isModerator() {
      return isAdmin() || (
        request.auth != null
        && exists(/databases/$(database)/documents/folio_roles/$(request.auth.uid))
        && 'moderator' in get(/databases/$(database)/documents/folio_roles/$(request.auth.uid)).data.roles
      );
    }
    // The parent folio_projects doc for a subcollection rule.
    function parentDoc(id) {
      return get(/databases/$(database)/documents/folio_projects/$(id));
    }
    function parentUid(id) {
      let d = parentDoc(id);
      return d != null ? d.data.uid : null;
    }
    function parentPublished(id) {
      let d = parentDoc(id);
      return d != null
        && d.data.release != null
        && d.data.release.published == true;
    }
    // Anyone who is allowed to SEE this folio: its owner, or anyone if
    // it's published.
    function folioVisible(id) {
      return isUser(parentUid(id)) || parentPublished(id);
    }

    match /folio_projects/{id} {
      // Read: the owner, or anyone if the folio is published.
      // A LIST query is only permitted when it's constrained to
      // where('uid','==', <me>) — the app's "my folios" query — because
      // then every result provably satisfies isUser(). An unfiltered
      // list of all folios is denied.
      // Read: owner, published-folio-viewer, OR admin (so /admin/shelf/
      // can see pending + rejected listings that aren't public-visible).
      allow read:   if isUser(resource.data.uid)
                    || (resource.data.release != null
                        && resource.data.release.published == true)
                    || isAdmin();

      // Create: the new doc must be stamped with the creator's own uid.
      allow create: if isUser(request.resource.data.uid);

      // Update / delete: must already own it. Checked against the
      // EXISTING doc — partial merge-updates (publishing a release,
      // setting shelfId) legitimately omit `uid` from the payload, so
      // the incoming data can't be relied on here.
      //
      // Admin update — Folio operators can update ANY folio doc so
      // /admin/boost can write release.featuredUntil on paying authors'
      // listings. Delete stays owner-only (safer default; admins can
      // demote by writing featuredUntil to null instead).
      allow update: if isUser(resource.data.uid) || isAdmin();
      allow delete: if isUser(resource.data.uid);

      // Manuscript body subdocs.
      //   body/main — free preview / non-paid content. Same visibility
      //               as the parent folio (owner OR published).
      //   body/paid — paid chapter content (audit D1). OWNER-ONLY
      //               from Firestore; non-owners get permission-denied
      //               on a direct read. The paywall worker fetches it
      //               via a service account on a license-verified
      //               request (see folio-paywall-worker.js
      //               /paid-content), so a buyer holding a valid JWT
      //               can still receive paid content — but no
      //               anonymous reader can.
      // Writes (both docs) are owner-only.
      match /body/{doc} {
        allow read:  if doc == 'paid'
                       ? isUser(parentUid(id))
                       : folioVisible(id);
        allow write: if isUser(parentUid(id));
      }

      // Version history — owner only, both directions.
      match /versions/{vid} {
        allow read, write: if isUser(parentUid(id));
      }

      // Character cast — written by characters.js (src/modules) when the
      // user adds / edits / deletes a character in Manage Characters.
      // Stored at folio_projects/<id>/characters/<charId>.
      //   Read: owner, or anyone if the folio is published (collaborators
      //         and readers can see the cast so dialogue colors / voices
      //         resolve on the share link too).
      //   Write: owner only — the cast is editorial, not reader content.
      match /characters/{charId} {
        allow read:  if folioVisible(id);
        allow write: if isUser(parentUid(id));
      }

      // Editorial metadata — single-doc helpers written by the modules
      // alongside the main body. Currently used for:
      //   metadata/dialogueAssignments  →  { chapterId: { hash: charId } }
      // Add new entries (per-character voice settings, narrator config,
      // etc.) under this same subcollection so they share the rule.
      //   Read:  owner OR anyone on a published folio (the audio worker
      //          and the dialogue-color highlight need this on the
      //          public share link).
      //   Write: owner only.
      match /metadata/{doc} {
        allow read:  if folioVisible(id);
        allow write: if isUser(parentUid(id));
      }

      // Live presence — readable by anyone who can see the folio; each
      // user may write only their own presence doc (it's keyed by uid).
      match /presence/{uid} {
        allow read:  if folioVisible(id);
        allow write: if isUser(uid);
      }

      // Annotations.
      // Per-doc scope enforcement (audit B4 — fixed). The folio owner
      // sees every annotation on their own folio; anyone else can read
      // an annotation only if its scope is 'public' OR they personally
      // authored it (uid match). Editor / collaborator / others'
      // personal notes no longer leak.
      //
      // A LIST query is permitted only when it's constrained so every
      // result satisfies one of those branches:
      //   • Owner — no filter needed (parentUid(id) is collection-level).
      //   • Non-owner — must query with either
      //       where('scope','==','public')
      //       where('uid','==', auth.uid)
      // The Folio client splits its subscription accordingly in
      // _annSubscribe / _annInitFromCloud.
      match /annotations/{aid} {
        allow read:   if isUser(parentUid(id))
                      || resource.data.scope == 'public'
                      || (request.auth != null
                          && resource.data.uid == request.auth.uid);
        // Create: stamped with your own uid — or anything, if you own
        // the folio (covers the owner migrating legacy annotations).
        allow create: if isUser(request.resource.data.uid)
                      || isUser(parentUid(id));
        // Update / delete: the annotation's author, or the folio owner.
        allow update, delete: if isUser(parentUid(id))
                      || isUser(resource.data.uid);
      }

      // Subscribers — the serial-release email list.
      match /subscribers/{sid} {
        // Anyone may CREATE a subscriber doc — that's the public
        // subscribe form. Restricted to exactly the three fields the
        // app writes (_subAdd), with a sane email length cap.
        allow create: if request.resource.data.keys()
                          .hasOnly(['email','subscribedAt','unsubscribeToken'])
                      && request.resource.data.email is string
                      && request.resource.data.email.size() < 320;

        // Locked down (audit B5 — done). Anonymous readers no longer
        // touch this subcollection: the unsubscribe link in chapter
        // emails now points at the folio-email worker's /unsubscribe
        // endpoint, which uses a Google service account (IAM, not
        // Firestore rules) to find + delete the matching doc. So
        // read + delete here are strictly the owner's prerogative —
        // closes the email-harvest / arbitrary-delete risk.
        allow read, delete: if isUser(parentUid(id));

        // Updates are owner-only regardless.
        allow update: if isUser(parentUid(id));
      }

      // Signed teaser links — per-folio Firestore-backed share tokens
      // that unlock ONE specific chapter for whoever holds the URL,
      // without making that chapter publicly listed in release.teasers.
      // Pattern: the owner mints a doc (tokenId = unguessable random)
      // with `{chapterId, createdAt}`. The reader URL carries the
      // tokenId in `?tt=`. The paywall worker reads the doc via its
      // service account to verify before returning the chapter content.
      //
      //   Read   : owner only at the rule layer (the worker uses a
      //            service account which bypasses rules — readers
      //            never touch this subcollection directly).
      //   Create : owner only, with a small payload shape lock so a
      //            malicious owner-session can't sneak unexpected
      //            fields into the doc.
      //   Update : never (regenerate by delete + create).
      //   Delete : owner only (revoke single link OR revoke-all
      //            via subcollection sweep).
      match /signed_teasers/{tokenId} {
        allow read, delete: if isUser(parentUid(id));
        allow create: if isUser(parentUid(id))
                      && request.resource.data.keys()
                           .hasOnly(['chapterId', 'createdAt'])
                      && request.resource.data.chapterId is string
                      && request.resource.data.chapterId.size() < 100;
        allow update: if false;
      }
    }

    // Per-user app settings — your own OR admin (needed for comping Press
    // subscriptions from /admin/press/ for testing + edge cases).
    match /folio_user_settings/{uid} {
      allow read, write: if isUser(uid) || isAdmin();
    }

    // Reviews / testimonials — authors submit reviews from the app + reader.
    // Each submission earns a free 24h Featured Boost on one of their folios
    // (the boost is applied server-side via the paywall worker's
    // /review-submit endpoint using its service account, which bypasses
    // these client-facing rules).
    //
    // Public display is admin-curated: approvedForDisplay is only set to
    // true by isAdmin() from /admin/reviews/. Anonymous readers can then
    // read those approved docs for the welcome-page testimonials scroll.
    match /reviews/{reviewId} {
      // Read: (a) publicly displayed reviews are readable by anyone;
      //       (b) authors can always see their own submissions.
      allow read: if (resource.data.approvedForDisplay == true
                     && resource.data.allowMarketing == true)
                  || isUser(resource.data.uid);
      // Create: must be signed in + submitting under your own uid.
      // Shape-lock keeps a rogue client from sneaking unexpected fields
      // (like pre-approving your own review).
      allow create: if isUser(request.resource.data.uid)
                    && request.resource.data.rating is number
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.text is string
                    && request.resource.data.text.size() >= 10
                    && request.resource.data.text.size() <= 500
                    && request.resource.data.approvedForDisplay == false;
      // Update: authors can edit their own text/rating/allowMarketing but
      //         cannot self-approve for display; admins can approve.
      allow update: if (isUser(resource.data.uid)
                        && request.resource.data.uid == resource.data.uid
                        && request.resource.data.approvedForDisplay == resource.data.approvedForDisplay)
                    || isAdmin();
      // Delete: author or admin.
      allow delete: if isUser(resource.data.uid) || isAdmin();
    }

    // Admin + moderator role assignments — used by isAdmin() and
    // isModerator() functions above. Managed via /admin/admins/.
    //   Read:  public — needed so client-side code can check role state
    //          without special permissions. Contents (uid + role names +
    //          display name) are not sensitive.
    //   Write: admin only. Bootstrap admins in isAdmin() can always
    //          write, so a fresh install can grant its first non-bootstrap
    //          admin without hitting a chicken-and-egg lock.
    match /folio_roles/{uid} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public imprint themes — Indie+ subscribers customize their /imprint/
    // page (accent color, hero image, header font). Anyone can READ (needed
    // to render another author's customized imprint to visitors), but only
    // the owner can WRITE their own theme. The client + worker separately
    // gate whether to APPLY the theme based on subscription status —
    // reading a theme doc without a valid Press subscription is safe
    // because it just returns styling values, not sensitive data.
    // Product-photo one-time purchases. Written by the paywall worker
    // via a service account when PayPal captures a $3 Order — clients
    // never write directly. Users can read their own purchases so the
    // /press/photos/ page can enable the Download button without a
    // worker round-trip.
    match /folio_photo_purchases/{captureId} {
      allow read:  if isUser(resource.data.uid) || isAdmin();
      allow write: if false;  // worker only (bypasses rules via SA)
    }

    match /folio_imprint_themes/{uid} {
      allow read: if true;
      // Owner writes their own customization; admins can also write to mark
      // fields like `foundingContributor` from /admin/press/ comp flow.
      allow write: if isUser(uid) || isAdmin();
    }

    // Lulu print-on-demand job records. Doc id is "<uid>_<jobId>" and
    // the payload carries `uid`. create checks the incoming payload;
    // read / update / delete check the EXISTING doc (no payload on a
    // read or delete). The app's list query is constrained to
    // where('uid','==', <me>), so it satisfies the read rule.
    match /lulu_jobs/{jobId} {
      allow create: if isUser(request.resource.data.uid);
      allow read, update, delete: if isUser(resource.data.uid);
    }

    // Anything not matched above is denied by default.
  }
}
